# Firebase Configuration
VITE_VERIFY_RECAPTCHA_URL=https://your_cloud_function_url
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_API_KEY_FIREBASE=your_firebase_api_key
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_PROJECT_ID=your_project_id
VITE_SORAGE_BUCKET=your_project.appspot.com
VITE_MESSAGING_SENDER_ID=your_sender_id
VITE_APP_ID=your_app_id

# Payment Configuration
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
VITE_PAYPAL_SANDBOX_CLIENT_ID=your_paypal_client_id
VITE_PAYPAL_LIVE_CLIENT_ID=your_paypal_client_id

# Currency Conversion API
VITE_CURRENCY_API_KEY=your_currency_api_key

# App Environment
VITE_APP_ENVIRONMENT=DEVELOPMENT

# Note: These should be your actual credentials
# Make sure to keep your .env.local file secure and never commit it to version control

# Backend
VITE_DEV_BACKEND_URL='http://localhost:3001/api/payment'
VITE_PROD_BACKEND_URL='https://us-central1-<project-id>.cloudfunctions.net'